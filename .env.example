# ─────────────────────────────────────────────────────────────────────────────
# EVA Comply — environment template
# Copy to ".env" for local docker-compose runs:  cp .env.example .env
# On Render, set these as service Environment Variables instead (see render.yaml
# and DEPLOY_RENDER.md). NEVER commit a filled-in .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Site-wide HTTP Basic Auth (the crawler / public gate) ────────────────────
# nginx returns 401 to anyone who doesn't send these. Pick a strong password.
BASIC_AUTH_USER=eva
BASIC_AUTH_PASSWORD=change_me_to_a_strong_password
# Set to "true" ONLY for local dev to disable the gate. Leave false in prod.
BASIC_AUTH_DISABLED=false

# ── App secret (JWT signing key) ─────────────────────────────────────────────
# Generate: openssl rand -hex 32   (must be >= 32 chars in production)
SECRET_KEY=change_me_run_openssl_rand_hex_32

# ── Database ─────────────────────────────────────────────────────────────────
# Local compose uses this password; in production use a managed DB URL.
POSTGRES_PASSWORD=change_me_strong_db_password
# Full async URL the API/worker use. For local compose leave as-is after setting
# POSTGRES_PASSWORD. On Render, point this at the managed Postgres (asyncpg form):
#   postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+asyncpg://eva_user:change_me_strong_db_password@db:5432/eva_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Environment ──────────────────────────────────────────────────────────────
# "production" turns on the safety guard (real SECRET_KEY, non-default DB pw,
# non-console email all required).
ENVIRONMENT=production

# Public URL of the frontend — used to build invite / reset / unlock links.
FRONTEND_URL=https://your-app.onrender.com

# ── Email (REQUIRED when ENVIRONMENT=production) ─────────────────────────────
# One of: smtp | sendgrid | ses   (console is rejected in production)
EMAIL_BACKEND=smtp
FROM_EMAIL=noreply@yourdomain.com
SENDGRID_API_KEY=
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ── Object storage for uploaded evidence (recommended on Render) ─────────────
# local | r2 | s3 . Render disks are per-service; use R2/S3 for durable evidence.
STORAGE_BACKEND=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=eva-uploads

# ── Billing (optional) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
